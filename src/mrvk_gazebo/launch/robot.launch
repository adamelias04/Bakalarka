<launch>
    <arg name="model" default="$(find mrvk_description)/urdf/robot.urdf.xacro"/>
    <!-- Drive plugin (gazebo_ros_skid_steer_drive) bezi v namespace 'shoddy/',
         takze odom je na /shoddy/odom, nie na /odom. -->
    <arg name="odom_topic" default="/shoddy/odom"/>
    <arg name="laser_topic" default="/scan"/>

    <arg name="world_file" default="$(find mrvk_gazebo)/worlds/empty.world"/>

    <arg name="init_x" default="0"/>
    <arg name="init_y" default="6"/>
    <arg name="init_z" default="0.3"/>
    <arg name="init_yaw" default="-1.57"/>

    <include file="$(find mrvk_gazebo)/launch/gazebo.launch">
        <arg name="model" value="$(arg model)"/>
        <arg name="world_file" value="$(arg world_file)"/>
        <arg name="init_x" value="$(arg init_x)"/>
        <arg name="init_y" value="$(arg init_y)"/>
        <arg name="init_z" value="$(arg init_z)"/>
        <arg name="init_yaw" value="$(arg init_yaw)"/>
    </include>

    <node name="rqt_robot_steering" pkg="rqt_robot_steering" type="rqt_robot_steering">
        <param name="default_topic" value="/cmd_vel_raw"/>
    </node>

    <node pkg="mrvk_gazebo"
          type="dynamic_obstacle_predictor"
          name="dynamic_obstacle_predictor"
          output="screen">

        <param name="scan_topic" value="$(arg laser_topic)"/>
        <param name="output_frame" value="odom"/>

        <param name="prediction_time" value="3.75"/>
        <param name="prediction_dt" value="0.1"/>

        <param name="alpha_gain" value="0.65"/>
        <param name="beta_gain" value="0.20"/>
        <param name="max_speed" value="2.0"/>
        <param name="track_timeout" value="1.2"/>
        <param name="lost_track_prediction_time" value="1.6"/>
        <param name="prediction_hold_time" value="0.8"/>
        <param name="prediction_hold_speed_epsilon" value="0.08"/>

        <param name="point_spacing" value="0.05"/>
        <param name="corridor_radius" value="0.18"/>
        <param name="object_half_extent" value="0.18"/>
        <param name="z_height" value="0.10"/>

        <param name="scan_range_min_use" value="0.10"/>
        <param name="scan_range_max_use" value="8.00"/>

        <param name="segment_jump_distance" value="0.30"/>
        <param name="segment_min_points" value="2"/>
        <param name="segment_max_points" value="120"/>

        <param name="segment_min_width" value="0.03"/>
        <param name="segment_max_width" value="2.00"/>

        <!-- NA ZACIATOK ROI VYPNUTE -->
        <param name="use_angle_roi" value="false"/>
        <param name="angle_min_roi" value="-1.57"/>
        <param name="angle_max_roi" value="1.57"/>

        <param name="use_range_roi" value="false"/>
        <param name="range_min_roi" value="0.20"/>
        <param name="range_max_roi" value="8.00"/>

        <param name="initial_expected_angle" value="0.0"/>
        <param name="initial_expected_range" value="2.5"/>

        <param name="max_association_distance" value="2.0"/>

        <param name="publish_debug_segment" value="true"/>
    </node>

    <!-- <node name="image_view" pkg="image_view" type="image_view" args="image:=/camera/image_raw"/>-->

    <!-- gmapping pise "Laser Pose=" / "Registering Scans:Done" priamo na stdout
         z openslam kniznice (obchadza ROS logger), takze output="log" to
         neodfiltruje. Presmerujeme stdout na /dev/null cez launch-prefix. -->
    <node name="slam_gmapping" pkg="gmapping" type="slam_gmapping"
          launch-prefix="bash -c 'exec &quot;$@&quot; 1&gt;/dev/null' bash">
        <rosparam command="load" file="$(find mrvk_gazebo)/config/slam/gmapping.yaml"/>
        <remap from="/scan" to="$(arg laser_topic)"/>
    </node>

    <node pkg="mrvk_gazebo"
          type="safe_zone_goal_router"
          name="safe_zone_goal_router"
          output="screen">
        <param name="odom_topic" value="$(arg odom_topic)"/>
        <param name="local_costmap_topic" value="/move_base/local_costmap/costmap"/>
        <param name="output_frame" value="odom"/>
    </node>

    <!-- Safety filter: predikuje pohyb robota podla cmd_vel a aktualnej
         pozy, a v pripade hroziacej kolizie spomali / zastane / cuvne. -->
    <node pkg="mrvk_gazebo"
          type="robot_motion_predictor"
          name="robot_motion_predictor"
          output="screen">
        <param name="cmd_vel_in_topic" value="/cmd_vel_raw"/>
        <param name="cmd_vel_out_topic" value="/shoddy/cmd_vel"/>
        <param name="odom_topic" value="$(arg odom_topic)"/>
        <param name="local_costmap_topic" value="/move_base/local_costmap/costmap"/>
        <param name="prediction_path_topic" value="/robot_motion_prediction"/>
        <param name="prediction_marker_topic" value="/robot_motion_prediction_marker"/>

        <param name="prediction_time" value="2.0"/>
        <param name="viz_rate" value="20.0"/>
        <param name="marker_line_width" value="0.05"/>
        <param name="marker_z" value="0.10"/>
        <param name="prediction_dt" value="0.1"/>
        <param name="slow_horizon" value="1.0"/>
        <param name="stop_horizon" value="0.4"/>
        <param name="reverse_horizon" value="0.2"/>
        <param name="lethal_threshold" value="85"/>
        <param name="reverse_velocity" value="-0.15"/>
        <param name="reverse_clear_probe_distance" value="0.45"/>
        <param name="publish_prediction_path" value="true"/>

        <!-- Temporal overlap test proti /predicted_obstacle_path z
             dynamic_obstacle_predictor: porovnava robotovu predikciu
             a obstacle predikciu v rovnakych casovych krokoch a
             rozhoduje CROSSING (STOP) / HEAD-ON (passthrough pre TEB). -->
        <param name="obstacle_path_topic" value="/predicted_obstacle_path"/>
        <param name="obstacle_prediction_dt" value="0.1"/>
        <param name="temporal_safety_distance" value="0.48"/>
        <param name="temporal_path_max_age" value="1.0"/>
        <param name="temporal_prediction_time" value="3.0"/>

        <!-- Lethal escape mode: ak je robot v lethal bunke, vyhodnoti 8
             kandidatov (FWD / REV / FWD+rot / REV+rot / ROT) a vyberie ten,
             ktory najrychlejsie unika a najmenej sa blizi k prekazke. -->
        <param name="escape_horizon" value="1.5"/>
        <param name="escape_linear_velocity" value="1.5"/>
        <param name="escape_angular_velocity" value="0.6"/>

        <!-- Head-on maneuver: pri TEMPORAL_HEADON je primarna strategia
             REVERSE + TURN (cuvanie so zatacanim) — robot cuvne a sucasne
             rotuje, cim sa vyhne head-on kurzu a TEB dokaze prekazku obist.
             Fallback: cista reverze, potom forward swerve.
             Vyber maximalizuje min vzdialenost od prekazky pocas headon_horizon.
             Strana-lock hysteréza zabranuje preskakovaniu medzi L a R. -->
        <!-- Hodnoty prisposobene realnemu wheel_accel (~0.23 m/s² na koleso):
             vyssie targety kolesa nestihnu nabehnut za cas latch-u, takze
             diferencial (=zatacanie) sa nikdy neprejavi. Nizsie targety
             su fyzikalne dosiahnutelne v ramci latch okna. -->
        <param name="headon_reverse_velocity" value="-1.1"/>
        <param name="headon_swerve_angular" value="1.0"/>
        <param name="headon_forward_velocity" value="1.0"/>
        <param name="headon_horizon" value="1.2"/>
        <!-- Hard lock + dlhsie okno + vacsi bonus: ked sa robot raz committne
             do REV_L alebo REV_R, nekmita. Oba smery su symetricky bezpecne. -->
        <param name="headon_side_lock_time" value="2.0"/>
        <param name="headon_side_lock_bonus" value="0.25"/>
        <param name="headon_hard_lock" value="true"/>
        <!-- Permisivna feasibility: blokujeme iba ak prvych N krokov
             (0.1*N sekund) arc-u je v lethal. Neskorsie lethal steps
             neblokuju — dalsi tick reevaluuje s cerstvym costmapom. -->
        <param name="headon_min_feasible_steps" value="2"/>

        <!-- Command latch: HEADON/ESCAPE reverze sa zamkne na tento cas,
             aby TEB (~10Hz forward=1.0) nestihol medzitym prepisat cmd
             a robot reálne zreverzoval niekoľko decimetrov + zatocil.
             Dlhsie okno je nutne pretoze pri wheel_accel=2.0 rad/s²
             trva nabehnutie diferencialu aspon ~1.5-2s. -->
        <param name="cmd_latch_time" value="1.9"/>
    </node>

    <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
        <rosparam file="$(find mrvk_gazebo)/config/costmap/costmap_common.yaml" command="load" ns="global_costmap"/>
        <rosparam file="$(find mrvk_gazebo)/config/costmap/global_costmap.yaml" command="load"/>

        <rosparam file="$(find mrvk_gazebo)/config/costmap/costmap_common.yaml" command="load" ns="local_costmap"/>
        <rosparam file="$(find mrvk_gazebo)/config/costmap/local_costmap.yaml" command="load"/>

        <rosparam file="$(find mrvk_gazebo)/config/navigation/base_local_planner.yaml" command="load"/>
        <rosparam file="$(find mrvk_gazebo)/config/navigation/move_base.yaml" command="load"/>
        <rosparam file="$(find mrvk_gazebo)/config/navigation/dwa_local_planner.yaml" command="load"/>
        <rosparam file="$(find mrvk_gazebo)/config/navigation/teb_local_planner.yaml" command="load"/>

        <remap from="/cmd_vel" to="/cmd_vel_raw"/>
        <remap from="/move_base_simple/goal" to="/managed_move_base_simple/goal"/>
        <remap from="odom" to="$(arg odom_topic)"/>
        <remap from="scan" to="$(arg laser_topic)"/>
    </node>
</launch>
